    <style>
        :root {
            --bg:         #070f1c;
            --gold:       #c49a2a;
            --gold-light: #e8b84b;
            --gold-dim:   rgba(196, 154, 42, 0.32);
            --text-dim:   #7a7268;
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'IM Fell English', Georgia, serif;
            margin: 0;
            padding: 0;
            background: var(--bg);
            overflow: hidden;
        }

        /* ── pygbag required ──────────────────────────── */
        #status {
            display: inline-block;
            vertical-align: top;
            margin-top: 20px;
            margin-left: 30px;
            font-weight: bold;
            color: rgb(120, 120, 120);
        }
        #progress { height: 20px; width: 300px; }
        div.emscripten { text-align: center; }
        div.emscripten_border { border: 1px solid black; }
        div.thick_border { border: 4px solid black; }

        /* the canvas *must not* have any border or padding, or mouse coords will be wrong */
        canvas.emscripten {
            border: 0px none;
            background-color: transparent;
            width: 100%;
            height: 100%;
            z-index: 5;
            padding: 0;
            margin: 0 auto;
            position: absolute;
            top: 0;
            bottom: 0;
            left: 0;
            right: 0;
        }

        .topright    { position: absolute; top: 0; right: 0; }
        .bottomright { position: absolute; top: 40%; right: 0; }
        .center      { display: flex; align-items: center; justify-content: center; }
        .trinfo      { position: relative; right: 0; border: 1px solid black; }
        .framed      { position: relative; top: 150px; right: 10px; border: 1px solid black; }

        /* ── Splash screen ───────────────────────────── */
        #splash {
            position: fixed;
            inset: 0;
            z-index: 20;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: var(--bg);
            transition: opacity 0.9s ease;
        }
        #splash.fade-out {
            opacity: 0;
            pointer-events: none;
        }

        /* Triangular lattice (dual of hex grid) as texture */
        #splash-bg {
            position: absolute;
            inset: 0;
            background-image:
                repeating-linear-gradient(  0deg, transparent 0px, transparent 57px, rgba(196,154,42,0.055) 57px, rgba(196,154,42,0.055) 58px),
                repeating-linear-gradient( 60deg, transparent 0px, transparent 57px, rgba(196,154,42,0.055) 57px, rgba(196,154,42,0.055) 58px),
                repeating-linear-gradient(120deg, transparent 0px, transparent 57px, rgba(196,154,42,0.055) 57px, rgba(196,154,42,0.055) 58px);
            pointer-events: none;
        }
        /* Radial vignette — focuses attention on center */
        #splash-vignette {
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 52% 62% at 50% 44%, transparent, var(--bg) 90%);
            pointer-events: none;
        }

        .splash-inner {
            position: relative;
            z-index: 1;
            text-align: center;
            padding: 40px 24px;
            animation: splash-reveal 1.1s cubic-bezier(0.16, 1, 0.3, 1) both;
        }
        @keyframes splash-reveal {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .hex-emblem {
            display: block;
            margin: 0 auto 28px;
            width: 54px;
            height: 54px;
        }
        .hex-emblem polygon {
            fill: none;
            stroke: var(--gold);
            stroke-width: 1.5;
            animation: hex-pulse 3.5s ease-in-out infinite;
        }
        @keyframes hex-pulse {
            0%, 100% { stroke: var(--gold-dim);   filter: drop-shadow(0 0 3px rgba(196,154,42,0.15)); }
            50%       { stroke: var(--gold-light); filter: drop-shadow(0 0 16px rgba(232,184,75,0.55)); }
        }

        .game-title {
            font-family: 'Cinzel', serif;
            font-weight: 900;
            font-size: clamp(46px, 7.5vw, 92px);
            color: var(--gold-light);
            letter-spacing: 0.13em;
            line-height: 1;
            margin: 0 0 8px;
            text-shadow:
                0 0 80px rgba(196,154,42,0.4),
                0 2px 30px rgba(0,0,0,0.95);
        }

        .game-tagline {
            font-family: 'Cinzel', serif;
            font-size: clamp(9px, 1.05vw, 12px);
            letter-spacing: 0.48em;
            color: var(--text-dim);
            text-transform: uppercase;
            margin: 0 0 26px;
        }

        .splash-rule {
            width: 160px;
            height: 1px;
            margin: 0 auto 26px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
            opacity: 0.5;
        }

        .game-desc {
            font-size: clamp(15px, 1.35vw, 18px);
            line-height: 1.82;
            color: var(--text-dim);
            font-style: italic;
            max-width: 440px;
            margin: 0 auto;
        }

        /* ── Infobox: loading status & click-to-start CTA ── */
        #infobox {
            position: fixed;
            left: 50%;
            top: 74vh;
            transform: translate(-50%, -50%);
            white-space: nowrap;
            background: transparent;
            color: var(--gold-light);
            font-family: 'Cinzel', serif;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.38em;
            text-transform: uppercase;
            padding: 14px 48px;
            border: 1px solid var(--gold);
            z-index: 999999;
            animation: infobox-breathe 2.8s ease-in-out infinite;
        }
        @keyframes infobox-breathe {
            0%, 100% {
                border-color: var(--gold-dim);
                box-shadow: none;
                color: rgba(232,184,75,0.65);
            }
            50% {
                border-color: var(--gold-light);
                box-shadow: 0 0 30px rgba(196,154,42,0.22), inset 0 0 30px rgba(196,154,42,0.04);
                color: var(--gold-light);
            }
        }
    </style>

